APP_NAME=Pizza Lab API
APP_ENV=development
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173
MONGO_URI=mongodb://localhost:27017
MONGO_DB=pizza_lab
# Asgardeo (org: orgfvzwp) — issuer/JWKS must match your tenant:
# https://api.asgardeo.io/t/orgfvzwp/oauth2/.well-known/openid-configuration
WSO2_ISSUER=https://api.asgardeo.io/t/orgfvzwp/oauth2/token
WSO2_JWKS_URL=https://api.asgardeo.io/t/orgfvzwp/oauth2/jwks
# Your Asgardeo application client ID (JWT "aud" / introspection)
WSO2_AUDIENCE=<your-asgardeo-client-id>
WSO2_VERIFY_TLS=true
# Optional: if JWT validation fails with issuer mismatch, set to token "iss" from jwt.io (often accounts.asgardeo.io)
# WSO2_ISSUER_ALT=https://accounts.asgardeo.io/t/<org>/oauth2/token
# Opaque access tokens: introspection (keep secret only in local .env — do not commit)
ASGARDEO_INTROSPECT_CLIENT_ID=
ASGARDEO_INTROSPECT_CLIENT_SECRET=
